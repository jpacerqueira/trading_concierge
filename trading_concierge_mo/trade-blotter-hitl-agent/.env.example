# Variable reference for docker-compose overrides or local tooling.
# The hackathon stack injects these from the parent `.env` / compose `environment:`;
# you do not need to copy this file to run containers.

# Trade REST API — direct HITL tools (trade_api_*)
TRADE_API_BASE_URL=http://trade-api:8000
TRADE_API_DIRECT_TOOLS=true
# TRADE_API_BEARER_TOKEN=
# USE_MOCK_API=false
# MX_USERNAME=...
# MX_PASSWORD=...
# MX_GROUP=...
# MX_FO_DESK=...
# MX_LOAD_BALANCER_URL=https://...
# MX_VERIFY_SSL=false

# MCP HTTP bridge (inside compose: http://mcp-server:7001)
MCP_BRIDGE_URL=http://mcp-server:7001
MCP_BRIDGE_TIMEOUT=30
# MCP_BRIDGE_TOKEN=

GOOGLE_API_KEY=
ADK_MODEL=gemini-3.1-pro-preview

# HITL classification (container path)
TOOL_CLASSIFICATION_PATH=/app/assets/tool_classification.yaml
HITL_FAIL_CLOSED=true

# A2A sidecar (see docker-compose A2A_PORT)
A2A_PORT=8100
A2A_ENABLED=true

# Compiled skills digest (MCP resources + prompts + tools + desktop policy) in ADK instruction
HITL_SKILLS_MAX_CHARS=120000
# HITL_WRITE_SKILLS_SNAPSHOT=false
# HITL_SKILLS_SNAPSHOT_PATH=assets/cache/compiled_skills.md
