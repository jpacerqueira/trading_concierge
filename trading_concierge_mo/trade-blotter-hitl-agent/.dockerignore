# Keep the build context lean.
.git
.gitignore
.github

# Python build/cache artifacts
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
build/
dist/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.env
.env.*

# Tests aren't needed inside the image.
tests/

# Local notes / editor noise
.DS_Store
.idea/
.vscode/
*.swp

# Docker scaffolding shouldn't recursively COPY itself.
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml
